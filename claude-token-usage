#!/usr/bin/env python3
"""claude-token-usage — wrapper script for symlink installs.

Works whether tokstat is installed via pip or via the repo symlink method:
  ln -s $(pwd)/claude-token-usage ~/.local/bin/claude-token-usage
"""
import sys
import os

try:
    from tokstat.cli import cli
except ImportError:
    # Not installed via pip — load from src/ relative to this script
    src = os.path.join(os.path.dirname(os.path.abspath(__file__)), "src")
    sys.path.insert(0, src)
    from tokstat.cli import cli

cli()
